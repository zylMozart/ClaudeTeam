# ClaudeTeam docker compose 配置模板
# 用法: cp .env.example .env 然后按需修改

# ── 飞书 App 凭证 (推荐路径) ──────────────────────────────────
# 填入你在 https://open.feishu.cn 创建的应用的 App ID 和 App Secret。
# 容器启动时会把这两个值写入容器**内部**的 lark-cli config.json,
# 完全不依赖宿主机 ~/.lark-cli —— 同机多部署之间、宿主机与容器之间
# 的飞书身份彻底隔离,也不会被其他 ClaudeTeam 部署看到。
#
# 如果你是老用户,已经在宿主机跑过 `npx @larksuite/cli config init --new`,
# 也可以留空这两个变量,然后在 docker-compose.yml 里取消注释
# ~/.lark-cli 和 ~/.local/share/lark-cli 的 bind mount,容器会复用宿主机配置。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 品牌: feishu (中国版, open.feishu.cn) 或 lark (国际版, open.larksuite.com)
FEISHU_BRAND=feishu

# ── Claude Code API Key (可选) ───────────────────────────────
# 如果宿主机已经 `claude login` 生成了 ~/.claude.json 和
# ~/.claude/.credentials.json, 这一项可以留空 ——
# docker-compose.yml 会通过 bind mount 复用宿主机 OAuth 凭证。
# Claude 凭证在同一账号的多个部署之间共享通常没问题,所以默认这样。
ANTHROPIC_API_KEY=

# ── Docker Compose 项目名 (同机多团队必填) ──────────────────
# docker-compose.yml 故意不写 container_name, 同机多团队部署依赖 Compose
# project name 做容器/volume/network 隔离。留空时 Compose 会 fallback 到
# 当前目录 basename —— 只要两个团队在不同目录就够用,单机单团队可以忽略本项。
#
# 同机多团队推荐把 project name 和 team.json 的 session 绑定,例如:
#   COMPOSE_PROJECT_NAME=claudeteam-test5
# 这样 docker ps 会看到 claudeteam-test5-team-1, 一眼分辨是哪个团队。
# scripts/docker-deploy.sh 会自动从 team.json 派生并 export, 走脚本的用户
# 可以不填本项。
#COMPOSE_PROJECT_NAME=claudeteam-myteam

# ── Kimi CLI 凭据 (kimi-code agent 用户) ─────────────────────
# .kimi-credentials/ 通过 bind mount 挂载到容器内 ~/.kimi/。
# 首次 docker compose up 时 kimi agent 会弹设备码登录,授权后凭据
# 自动保存到该目录。后续容器重建自动复用,无需重新登录。
# 如果登录过期: rm -rf .kimi-credentials/ 再 docker compose restart。

# ── 容器资源限制 ──────────────────────────────────────────────
# 默认针对 2C/4G 小机器。大机器上可以调高,比如 4G → 8G, 2.0 → 4.0。
CLAUDETEAM_CPUS=2.0
CLAUDETEAM_MEM=4G
