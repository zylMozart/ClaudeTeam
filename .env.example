# ClaudeTeam docker compose 配置模板
# 用法: cp .env.example .env 然后按需修改

# ── 飞书 App 凭证 (推荐路径) ──────────────────────────────────
# 填入你在 https://open.feishu.cn 创建的应用的 App ID 和 App Secret。
# 容器启动时会把这两个值写入容器**内部**的 lark-cli config.json,
# 完全不依赖宿主机 ~/.lark-cli —— 同机多部署之间、宿主机与容器之间
# 的飞书身份彻底隔离,也不会被其他 ClaudeTeam 部署看到。
#
# 如果你是老用户,已经在宿主机跑过 `npx @larksuite/cli config init --new`,
# 也可以留空这两个变量,然后在 docker-compose.yml 里取消注释
# ~/.lark-cli 和 ~/.local/share/lark-cli 的 bind mount,容器会复用宿主机配置。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 品牌: feishu (中国版, open.feishu.cn) 或 lark (国际版, open.larksuite.com)
FEISHU_BRAND=feishu

# ── Claude Code API Key (可选) ───────────────────────────────
# 如果宿主机已经 `claude login` 生成了 ~/.claude.json 和
# ~/.claude/.credentials.json, 这一项可以留空 ——
# docker-compose.yml 会通过 bind mount 复用宿主机 OAuth 凭证。
# Claude 凭证在同一账号的多个部署之间共享通常没问题,所以默认这样。
ANTHROPIC_API_KEY=

# ── 容器资源限制 ──────────────────────────────────────────────
# 默认针对 2C/4G 小机器。大机器上可以调高,比如 4G → 8G, 2.0 → 4.0。
CLAUDETEAM_CPUS=2.0
CLAUDETEAM_MEM=4G
