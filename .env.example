# ClaudeTeam docker compose 配置
# 用法: cp .env.example .env 然后按需修改

# ── 飞书 App 凭证 ─────────────────────────────────────────────
# 二选一:
#   (a) 这里填明文 App ID / Secret,容器启动时会自动生成
#       ~/.lark-cli/config.json(inline 格式),不需要宿主机预先跑
#       `lark-cli config init --new`。适合从零部署的新用户。
#   (b) 这里留空,然后在宿主机跑一次 `npx @larksuite/cli config init --new`
#       扫码完成首次初始化,docker-compose.yml 会把 ~/.lark-cli 和
#       ~/.local/share/lark-cli volume 挂载进容器复用。适合已经有
#       lark-cli 环境的老用户。
# 如果这里填了值,会覆盖宿主机挂载的 config.json。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 品牌: feishu (中国版, open.feishu.cn) 或 lark (国际版, open.larksuite.com)
FEISHU_BRAND=feishu

# ── Claude Code API Key (可选) ───────────────────────────────
# 如果宿主机已经 `claude login` 生成了 ~/.claude.json 和
# ~/.claude/.credentials.json, 这一项可以留空 ——
# docker-compose.yml 会通过 volume mount 复用宿主机 OAuth 凭证。
ANTHROPIC_API_KEY=

# ── 容器资源限制 ──────────────────────────────────────────────
# 默认针对 2C/4G 小机器。大机器上可以调高,比如 4G → 8G, 2.0 → 4.0。
CLAUDETEAM_CPUS=2.0
CLAUDETEAM_MEM=4G
