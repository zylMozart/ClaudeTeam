# ClaudeTeam docker compose 可调参数
# 用法: cp .env.example .env 然后按需修改

# Claude Code API Key(可选)
# 如果宿主机已经 `claude login` 生成了 ~/.claude.json + ~/.claude/.credentials.json,
# 这一项可以留空, docker-compose.yml 会通过 volume mount 复用宿主机凭证。
ANTHROPIC_API_KEY=

# 容器资源限制(默认针对 2C/4G 小机器)
# 大机器上可以调高, 比如 4G → 8G, 2.0 → 4.0
CLAUDETEAM_CPUS=2.0
CLAUDETEAM_MEM=4G
