# ClaudeTeam Docker deployment environment.
# Copy to `.env` and fill in your values:
#   cp .env.example .env && $EDITOR .env
# `.env` is gitignored. Keep your real secrets out of commits.

# ─── Feishu (Lark) custom app credentials ────────────────────────────
# Get these from open.feishu.cn/app → your app → Credentials and Basic
# Info. Use the bundled scripts/feishu_bot_creator/ to create the app
# in one command if you don't have one yet.
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxx
FEISHU_APP_SECRET=

# `lark-cli` reads either FEISHU_APP_* or its own LARKSUITE_CLI_APP_*
# names. Set both for forward-compat with whichever lark-cli build the
# image bundles. (Same value as the FEISHU_* pair above.)
LARKSUITE_CLI_APP_ID=${FEISHU_APP_ID}
LARKSUITE_CLI_APP_SECRET=${FEISHU_APP_SECRET}

# ─── send_as identity ────────────────────────────────────────────────
# Container deploys typically only have bot OAuth (the app_secret →
# tenant_token path), not user OAuth (which lives in macOS keychain on
# the host). Pin to bot so catchup / say / slash all use bot identity
# and don't trip `need_user_authorization`. Set to `user` only if your
# container has been logged in interactively with `lark-cli auth login`.
CLAUDETEAM_LARK_SEND_AS=bot

# ─── optional: Anthropic API key ─────────────────────────────────────
# If set, claude-code in the container uses this key directly instead
# of the interactive `claude /login` flow. Leave blank to use the host
# OAuth bind-mounted from ~/.claude/.credentials.json.
ANTHROPIC_API_KEY=

# ─── macOS Docker Desktop: tighter router stall threshold ────────────
# `network_mode: host` is only partially emulated by Docker Desktop on
# macOS / Windows; the lark-cli WebSocket subscribe routinely goes silent
# after a few minutes (caught 2026-05-07 docker smoke: cursor stuck for
# 4 min, missed every event after a quiet window). Halve the
# self-restart threshold so the router respawns + catches up sooner.
# Linux container hosts run real `host` mode and don't need this.
# CLAUDETEAM_ROUTER_STALE_S=300
