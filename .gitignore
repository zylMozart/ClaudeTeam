__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/
.pytest_cache/

# Python venv — per-developer; `pip install -e .` populates this
.venv/

# macOS noise
.DS_Store

# runtime state — anchor to repo root so src/claudeteam/agents/ isn't swallowed
/workspace/
/agents/
/projects/
/state/
# /scripts/ shouldn't exist on this branch (CLAUDE.md bans it), but
# left-over local checkouts of old main can carry stale runtime state
# under that name. Belt-and-suspenders so `git add -A` can't sweep
# .router.pid / runtime_config.json into a commit (caught round-79).
/scripts/
.claude/scheduled_tasks.lock
# `claudeteam install-hooks` output — regenerated per deploy
/.claude/commands/
team.json
runtime_config.json

# docker compose env (contains secrets)
.env
/team-data/
/docker-compose.override.yml

# unrelated tool caches that drift into the repo root
/.playwright-mcp/
